#!/bin/bash
# Simulate Clauddy pet states (dev).
#   ./pet fire        -> on fire (flames + shiver)
#   ./pet sleeping    -> sleeping (zzz)
#   ./pet working     -> working (eats tokens + hops)
#   ./pet tired       -> maxed out (slumped, sweat drop)
#   ./pet idle        -> idle
#   ./pet poke        -> one-shot squish + hearts
#   ./pet celebrate   -> one-shot jump + sparkles
#   ./pet auto        -> back to real data
DIR="$HOME/.claude-usage-monitor"
state="${1:-auto}"
mkdir -p "$DIR"

case "$state" in
  fire|sleeping|working|tired|idle|poke|celebrate|auto|clear) ;;
  *)
    echo "unknown state: $state"
    echo "use: fire | sleeping | working | tired | idle | poke | celebrate | auto"
    exit 1
    ;;
esac

printf '{"state":"%s","t":%s}\n' "$state" "$(date +%s)" > "$DIR/debug.json"
echo "pet -> $state"
