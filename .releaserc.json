{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/npm",
    ["@semantic-release/exec", { "prepareCmd": "bun run dist" }],
    [
      "@semantic-release/github",
      {
        "assets": [{ "path": "dist/*.zip", "label": "macOS app (Apple Silicon)" }],
        "successComment": false,
        "failComment": false,
        "failTitle": false
      }
    ]
  ]
}
